# Copie para .env e preencha os valores

PORT=3001

# Origem do front (Vercel em produção, localhost em dev)
CORS_ORIGIN=http://localhost:3000

# Secret para validar webhooks do Notification Service
WEBHOOK_SECRET=troque-por-um-secret-seguro

# URL base da API externa que o BFF consome
EXTERNAL_API_URL=https://api.exemplo.com
